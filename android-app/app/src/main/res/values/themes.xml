<?xml version="1.0" encoding="utf-8"?>
<!-- Match web POS: gradient background from first frame, light UI, no black screen -->
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.POSMobile" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="android:windowBackground">@drawable/bg_gradient</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <!-- Use full width on notched devices; insets applied in code on content root -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="28">shortEdges</item>
    </style>
</resources>
