<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="4dp"
    android:paddingEnd="@dimen/cart_header_padding_h"
    android:background="@drawable/cart_row_bg"
    android:minHeight="@dimen/cart_row_min_height">

    <TextView
        android:id="@+id/cart_item_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/cart_row_text_size"
        android:paddingEnd="4dp" />
    <EditText
        android:id="@+id/cart_qty"
        android:layout_width="@dimen/cart_row_cell_qty_width"
        android:layout_height="@dimen/cart_row_input_height"
        android:inputType="numberSigned"
        android:gravity="center"
        android:textSize="@dimen/cart_row_text_size"
        android:padding="4dp"
        android:background="@drawable/edit_text_web" />
    <TextView
        android:id="@+id/cart_price"
        android:layout_width="@dimen/cart_row_cell_price_width"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/cart_row_text_size" />
    <EditText
        android:id="@+id/cart_disc"
        android:layout_width="@dimen/cart_row_cell_disc_width"
        android:layout_height="@dimen/cart_row_input_height"
        android:inputType="numberSigned"
        android:gravity="center"
        android:textSize="@dimen/cart_row_text_size"
        android:padding="4dp"
        android:background="@drawable/edit_text_web"
        android:layout_marginStart="4dp" />
    <TextView
        android:id="@+id/cart_total"
        android:layout_width="@dimen/cart_row_cell_total_width"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/cart_row_text_size"
        android:textStyle="bold"
        android:layout_marginStart="4dp" />
    <ImageButton
        android:id="@+id/cart_remove"
        android:layout_width="@dimen/cart_row_icon_size"
        android:layout_height="@dimen/cart_row_icon_size"
        android:contentDescription="Remove"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="4dp" />
</LinearLayout>
